{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunRecord",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "estimateId",
    "taskId",
    "createdAt",
    "originalEstimateMinutes",
    "actualActiveMinutes",
    "wallClockMinutes",
    "outcome",
    "overestimateRatio",
    "redactionStatus",
    "rawContentStored",
    "secretValuesStored",
    "memoryIntegration"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string" },
    "estimateId": { "type": "string" },
    "taskId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "projectId": { "type": "string" },
    "taskType": { "type": "string" },
    "repoArea": { "type": "string" },
    "agentRole": { "type": "string" },
    "runtime": { "type": "string" },
    "model": { "type": "string" },
    "workflowLevel": { "type": "string" },
    "originalEstimateMinutes": { "type": "integer", "minimum": 0 },
    "humanBaselineMinutes": { "type": "integer", "minimum": 0 },
    "actualActiveMinutes": { "type": "integer", "minimum": 0 },
    "actualTimeSource": { "type": "string" },
    "wallClockMinutes": { "type": "integer", "minimum": 0 },
    "toolWaitMinutes": { "type": "integer", "minimum": 0 },
    "blockedMinutes": { "type": "integer", "minimum": 0 },
    "outcome": { "type": "string", "enum": ["pass", "needs_fix", "blocked"] },
    "verificationDepth": { "type": "string" },
    "qualityVerdict": { "type": "string" },
    "reworkCount": { "type": "integer", "minimum": 0 },
    "ownerGateHit": { "type": "boolean" },
    "overestimateRatio": { "type": "number" },
    "humanTimeBias": { "type": "boolean" },
    "slowReason": { "type": "string" },
    "redactionStatus": { "type": "string" },
    "rawContentStored": { "type": "boolean" },
    "secretValuesStored": { "type": "boolean" },
    "memoryIntegration": { "type": "string" }
  }
}
